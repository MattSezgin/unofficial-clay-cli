# Clay login - used ONLY to mint a local session cookie (stored one directory
# ABOVE this repo as ../.clay-session, refreshed automatically every ~23h).
# Never commit a real .env; this repo's .gitignore excludes it.
CLAY_EMAIL=you@example.com
CLAY_PASSWORD=change-me

# Your workspace (the number in your Clay app URL) - required for live commands.
CLAY_WORKSPACE_ID=123456

# Recommended: restrict all writes to one sandbox folder while you learn the tool.
CLAY_FOLDER_ID=

# Advanced: multiple write scopes as JSON, e.g.
# CLAY_WRITE_SCOPES=[{"name":"sandbox","workspaceId":"123456","folderId":"f_TEST_FOLDER"}]
